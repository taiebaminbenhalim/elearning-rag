# Copier ce fichier en .env et adapter les valeurs si besoin.
# Toute variable non définie utilise la valeur par défaut de config.py.

# --- PDF ---
PDF_IMAGE_OUTPUT_DIR=data/pages
PDF_ZOOM_FACTOR=2.0
PDF_IMAGE_FORMAT=png

# --- OCR ---
OCR_LANGUAGE=fra
OCR_MIN_CONFIDENCE=30.0
# Sous Windows uniquement, si Tesseract n'est pas dans le PATH, decommenter
# et adapter le chemin (utiliser des slashes normaux ou doubler les \\) :
# TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe

# --- Chunking (SemanticChunker) ---
CHUNKING_THRESHOLD_TYPE=percentile
CHUNKING_THRESHOLD_AMOUNT=95.0

# --- Embedding ---
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=16

# --- Vector Store (ChromaDB) ---
VECTOR_STORE_DIR=data/vector_store
VECTOR_STORE_COLLECTION=elearning_documents

# --- Dictionnaires de reference (V2) ---
# Chemins par defaut : data/dictionaries/*.json (relatif a la racine du projet).
# Decommenter uniquement pour utiliser des dictionnaires personnalises.
# SUBJECT_DETECTION_DICT_PATH=data/dictionaries/subject_detection.json
# LEVEL_INDICATORS_DICT_PATH=data/dictionaries/level_indicators.json
# STRUCTURE_INDICATORS_DICT_PATH=data/dictionaries/structure_indicators.json
